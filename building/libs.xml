		<lib name="lime" version="8.1.2" />
		<!-- <git name="lime" url="https://github.com/CodenameCrew/cne-lime" />  disabled for now until fixed -->

		<!-- Flixel -->
		<git name="flixel" url="https://github.com/CodenameCrew/cne-flixel" ref="5b1d4d6de0baa868809a59188071da07519fe05c" />
		<git name="flixel-addons" url="https://github.com/CodenameCrew/cne-flixel-addons" ref="38c0f548e678714b2885f710c2b4454fa2ce7058" />

